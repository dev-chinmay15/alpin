# Voice Agent Configuration

# =============================================================================
# LLM - Anthropic Claude
# =============================================================================
# Set via: export ANTHROPIC_API_KEY="your_key_here"
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =============================================================================
# HuggingFace Token (for model download)
# =============================================================================
# Set via: export HF_TOKEN="your_token_here"
# HF_TOKEN=your_huggingface_token_here

# =============================================================================
# STT Configuration
# Using local Whisper (FREE) - no API key needed!
# =============================================================================
STT_MODEL=whisper
WHISPER_MODEL_SIZE=base

# =============================================================================
# TTS Configuration
# Primary: Qwen3-TTS (requires GPU)
# Fallback: Edge TTS (Microsoft, FREE)
# =============================================================================
TTS_MODEL=Qwen/Qwen3-TTS-12Hz-0.6B-CustomVoice
TTS_SPEAKER=Ryan
TTS_LANGUAGE=English

# =============================================================================
# GPU Configuration
# =============================================================================
CUDA_VISIBLE_DEVICES=0

# =============================================================================
# Server Configuration (for Gradio UI)
# =============================================================================
HOST=0.0.0.0
PORT=7860
GRADIO_SHARE=false

# =============================================================================
# Audio Configuration
# =============================================================================
SAMPLE_RATE=24000
CHANNELS=1
