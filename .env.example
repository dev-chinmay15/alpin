# Qwen3-TTS Megakernel + Pipecat Configuration
# Copy this to .env and fill in your values

# =============================================================================
# LLM API Keys (Google Gemini)
# =============================================================================
GOOGLE_API_KEY=your_google_api_key_here

# =============================================================================
# STT Configuration
# Using local Whisper (FREE) - no API key needed!
# =============================================================================
STT_MODEL=whisper
WHISPER_MODEL_SIZE=base

# =============================================================================
# Model Configuration
# =============================================================================
MODEL_NAME=Qwen/Qwen3-TTS
USE_MEGAKERNEL=true
MAX_SEQ_LEN=2048

# =============================================================================
# GPU Configuration
# =============================================================================
CUDA_VISIBLE_DEVICES=0

# =============================================================================
# Server Configuration (for Gradio UI)
# =============================================================================
HOST=0.0.0.0
PORT=7860
GRADIO_SHARE=false

# =============================================================================
# Audio Configuration
# =============================================================================
SAMPLE_RATE=24000
CHANNELS=1
