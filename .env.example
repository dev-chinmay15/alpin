# Voice Agent Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# LLM - Anthropic Claude (REQUIRED)
# =============================================================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =============================================================================
# HuggingFace Token (Optional, for model download)
# =============================================================================
# HF_TOKEN=your_huggingface_token_here

# =============================================================================
# STT Configuration
# Optional: local Whisper STT (FREE) - install openai-whisper if needed
# =============================================================================
STT_MODEL=whisper
WHISPER_MODEL_SIZE=base

# =============================================================================
# TTS Configuration
# Primary: Qwen3-TTS (requires GPU)
# Fallback: Mock audio (for testing without GPU)
# =============================================================================
TTS_MODEL=Qwen/Qwen3-TTS-12Hz-0.6B-CustomVoice
TTS_SPEAKER=Ryan
TTS_LANGUAGE=English
MODEL_NAME=Qwen/Qwen3-TTS-12Hz-0.6B-CustomVoice
USE_MEGAKERNEL=true

# =============================================================================
# GPU Configuration
# =============================================================================
CUDA_VISIBLE_DEVICES=0

# =============================================================================
# Server Configuration (for Gradio UI)
# =============================================================================
HOST=0.0.0.0
PORT=7860
GRADIO_SHARE=false

# =============================================================================
# Audio Configuration
# =============================================================================
SAMPLE_RATE=24000
CHANNELS=1
