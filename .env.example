# Voice Agent Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# LLM - Anthropic Claude (REQUIRED)
# Get your API key at: https://console.anthropic.com/
# =============================================================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =============================================================================
# STT Configuration
# Using local Whisper (FREE) - no API key needed!
# =============================================================================
STT_MODEL=whisper
WHISPER_MODEL_SIZE=base

# =============================================================================
# TTS Configuration
# Using Edge TTS (Microsoft, FREE) - no API key needed!
# Available voices: en-US-AriaNeural, en-US-GuyNeural, en-GB-SoniaNeural
# =============================================================================
TTS_VOICE=en-US-AriaNeural

# =============================================================================
# GPU Configuration
# =============================================================================
CUDA_VISIBLE_DEVICES=0

# =============================================================================
# Server Configuration (for Gradio UI)
# =============================================================================
HOST=0.0.0.0
PORT=7860
GRADIO_SHARE=false

# =============================================================================
# Audio Configuration
# =============================================================================
SAMPLE_RATE=24000
CHANNELS=1
